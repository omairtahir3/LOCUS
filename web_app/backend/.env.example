# MongoDB — same DB as Python service
MONGO_URI=mongodb://localhost:27017/locusDB

# Server
PORT=5000
NODE_ENV=development

# JWT — use the SAME secret key as Python service so tokens work across both
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Email notifications (configure with your SMTP provider)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=LOCUS <your_email@gmail.com>

# Python AI service URL (for internal communication)
PYTHON_SERVICE_URL=http://localhost:8000
